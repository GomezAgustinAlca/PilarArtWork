---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { siteConfig, whatsappLink } from '../config/site';

const exposiciones = (await getCollection('exposiciones')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
);

const tipoLabel: Record<string, string> = { individual: 'Individual', colectiva: 'Colectiva' };
const formatearFecha = (fecha: Date) =>
  new Intl.DateTimeFormat('es-AR', { year: 'numeric', month: 'long' }).format(fecha);
---

<Layout
  title={`Exposiciones — ${siteConfig.artistName}`}
  description={`Muestras individuales y colectivas de ${siteConfig.artistName}, orden cronológico.`}
>
  <header class="page-header container">
    <p class="eyebrow">Trayectoria</p>
    <h1>Exposiciones</h1>
  </header>

  {
    exposiciones.length === 0 ? (
      <div class="container empty-state" data-reveal>
        <p>
          Todavía no hay exposiciones cargadas en esta sección. Mientras tanto, escribinos
          por WhatsApp si querés conocer la trayectoria de {siteConfig.artistName}.
        </p>
        <a class="btn btn-primary" href={whatsappLink('Hola! Quería consultar sobre las exposiciones.')}>
          Escribir por WhatsApp
        </a>
      </div>
    ) : (
  <ul class="container exposiciones-list">
    {
      exposiciones.map((expo) => (
        <li class={`expo-item ${!expo.data.imagen ? 'expo-item--full' : ''}`} data-reveal>
          {expo.data.imagen && (
            <div class="expo-media">
              <Image src={expo.data.imagen} alt={expo.data.titulo} width={320} height={220} />
            </div>
          )}
          <div class="expo-info">
            <p class="expo-fecha">{formatearFecha(expo.data.fecha)}</p>
            <h2>{expo.data.titulo}</h2>
            <p class="expo-lugar">
              {expo.data.lugar} · {expo.data.ciudad}
            </p>
            <span class={`badge-tipo badge-tipo--${expo.data.tipo}`}>{tipoLabel[expo.data.tipo]}</span>
            <p class="expo-desc">{expo.data.descripcion}</p>
          </div>
        </li>
      ))
    }
  </ul>
    )
  }
</Layout>

<style>
  .page-header {
    padding-block: var(--space-8) var(--space-6);
  }

  .eyebrow {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-2);
  }

  .exposiciones-list {
    list-style: none;
    padding-bottom: var(--space-10);
  }

  .empty-state {
    max-width: 40rem;
    padding-block: var(--space-8) var(--space-12);
    text-align: center;
    margin-inline: auto;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .expo-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .expo-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .expo-media :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .expo-fecha {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-1);
  }

  .expo-info h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .expo-lugar {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .badge-tipo {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .badge-tipo--individual {
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
  }

  .expo-desc {
    color: var(--color-text-muted);
    margin: 0;
  }

  .expo-item--full .expo-info {
    grid-column: 1 / -1;
  }

  @media (min-width: 768px) {
    .expo-item {
      grid-template-columns: 240px 1fr;
      align-items: start;
    }
  }
</style>
