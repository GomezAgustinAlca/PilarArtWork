---
---

<div class="lightbox" id="lightbox" hidden>
  <div class="lightbox-backdrop" data-lightbox-close></div>
  <div class="lightbox-panel" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Cerrar">×</button>

    <div class="lightbox-stage">
      <img class="lightbox-image" id="lightbox-image" data-lightbox-image alt="" />
      <span class="lightbox-zoom-hint" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
          <line x1="11" y1="8" x2="11" y2="14" />
          <line x1="8" y1="11" x2="14" y2="11" />
        </svg>
      </span>
    </div>

    <div class="lightbox-thumbs" id="lightbox-thumbs" hidden></div>

    <div class="lightbox-info">
      <h2 id="lightbox-title"></h2>
      <p class="lightbox-meta" id="lightbox-meta-principal"></p>
      <p class="lightbox-meta" id="lightbox-meta-dimensiones"></p>
      <p class="lightbox-meta" id="lightbox-meta-serie" hidden></p>
      <p class="lightbox-desc" id="lightbox-desc"></p>

      <div class="lightbox-compra" id="lightbox-compra" hidden>
        <span class="lightbox-precio" id="lightbox-precio"></span>
        <a class="btn-whatsapp" id="lightbox-whatsapp" target="_blank" rel="noopener noreferrer">
          Consultar / Comprar
        </a>
      </div>
      <p class="lightbox-badge" id="lightbox-badge" hidden>Vendida</p>
    </div>
  </div>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    padding: var(--space-5);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox:not([hidden]) {
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .lightbox.is-open {
    opacity: 1;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(43, 39, 36, 0.6);
  }

  .lightbox-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    grid-template-areas:
      'stage info'
      'thumbs info';
    align-items: start;
    gap: var(--space-6);
    background: var(--color-bg-elevated);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    max-width: 1100px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    padding: var(--space-6);
    transform: scale(0.96) translateY(12px);
    transition: transform var(--transition-base);
  }

  .lightbox.is-open .lightbox-panel {
    transform: none;
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: none;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    font-size: var(--text-xl);
    line-height: 1;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }

  .lightbox-close:hover {
    color: var(--color-accent);
  }

  .lightbox-stage {
    grid-area: stage;
    position: relative;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 70vh;
    width: auto;
    height: auto;
    object-fit: contain;
    cursor: zoom-in;
    opacity: 0;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .lightbox-image.is-ready {
    opacity: 1;
  }

  .lightbox-stage:hover .lightbox-image:not(.zoomed) {
    transform: scale(1.08);
  }

  .lightbox-image.zoomed {
    transform: scale(2);
    cursor: zoom-out;
  }

  .lightbox-zoom-hint {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(43, 39, 36, 0.55);
    color: var(--color-bg-elevated);
    pointer-events: none;
  }

  .lightbox-thumbs {
    grid-area: thumbs;
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .lightbox-thumbs[hidden] {
    display: none;
  }

  /*
    :global() because these buttons/imgs are created with document.createElement
    in gallery.js — Astro's scoped-style attribute is only applied to markup
    written in this component's template, so a plain scoped selector never
    matches JS-injected elements.
  */
  .lightbox-thumbs :global(.lightbox-thumb) {
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: none;
    width: 4.5rem;
    height: 5.5rem;
    flex-shrink: 0;
  }

  .lightbox-thumbs :global(.lightbox-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lightbox-thumbs :global(.lightbox-thumb.active) {
    border-color: var(--color-accent);
  }

  .lightbox-info {
    grid-area: info;
    min-width: 0;
  }

  .lightbox-info h2 {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .lightbox-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-1);
  }

  .lightbox-meta[hidden] {
    display: none;
  }

  .lightbox-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin: var(--space-4) 0;
  }

  .lightbox-compra {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .lightbox-compra[hidden] {
    display: none;
  }

  .lightbox-precio {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-text);
  }

  .btn-whatsapp {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-bg-elevated);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
  }

  .btn-whatsapp:hover {
    background: var(--color-accent-hover);
  }

  .lightbox-badge {
    display: inline-block;
    margin-top: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  .lightbox-badge[hidden] {
    display: none;
  }

  @media (max-width: 720px) {
    .lightbox-panel {
      grid-template-columns: 1fr;
      grid-template-areas:
        'stage'
        'thumbs'
        'info';
    }
  }
</style>
