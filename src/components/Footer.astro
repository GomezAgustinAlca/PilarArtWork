---
import { siteConfig, whatsappLink } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer-inner">
    <div class="footer-brand">
      <p class="footer-name">{siteConfig.artistName}</p>
      <p class="footer-tagline">{siteConfig.tagline}</p>
    </div>

    <nav class="footer-links" aria-label="Redes y contacto">
      <ul>
        {
          siteConfig.socials.instagram && (
            <li>
              <a href={siteConfig.socials.instagram} target="_blank" rel="noopener noreferrer">
                Instagram
              </a>
            </li>
          )
        }
        {
          siteConfig.socials.facebook && (
            <li>
              <a href={siteConfig.socials.facebook} target="_blank" rel="noopener noreferrer">
                Facebook
              </a>
            </li>
          )
        }
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>
          <a href={whatsappLink('Hola! Quería hacerte una consulta.')} target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        </li>
      </ul>
    </nav>

    <p class="footer-copy">© {year} {siteConfig.artistFullName}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-9);
  }

  .site-footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-6);
  }

  .footer-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text);
    margin: 0;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin: 0;
  }

  .footer-links ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    list-style: none;
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent-hover);
  }

  .footer-copy {
    width: 100%;
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: 0;
  }

  @media (min-width: 768px) {
    .footer-copy {
      width: auto;
      order: 3;
    }
  }
</style>
