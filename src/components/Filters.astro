---
import type { CollectionEntry } from 'astro:content';

interface Props {
  obras: CollectionEntry<'obras'>[];
}

const { obras } = Astro.props;

const series = [...new Set(obras.map((o) => o.data.serie).filter((s): s is string => Boolean(s)))].sort((a, b) =>
  a.localeCompare(b)
);
const tecnicas = [...new Set(obras.map((o) => o.data.tecnica))].sort((a, b) => a.localeCompare(b));
const anios = [...new Set(obras.map((o) => o.data.anio))].sort((a, b) => b - a);
---

<div class="filters" id="filters">
  <div class="filter-field">
    <label for="filtro-serie">Serie</label>
    <select id="filtro-serie" data-filter="serie">
      <option value="">Todas</option>
      <option value="__sin_serie__">Sin serie</option>
      {series.map((serie) => <option value={serie}>{serie}</option>)}
    </select>
  </div>
  <div class="filter-field">
    <label for="filtro-tecnica">Técnica</label>
    <select id="filtro-tecnica" data-filter="tecnica">
      <option value="">Todas</option>
      {tecnicas.map((tecnica) => <option value={tecnica}>{tecnica}</option>)}
    </select>
  </div>
  <div class="filter-field">
    <label for="filtro-anio">Año</label>
    <select id="filtro-anio" data-filter="anio">
      <option value="">Todos</option>
      {anios.map((anio) => <option value={anio}>{anio}</option>)}
    </select>
  </div>
  <button type="button" id="filtros-reset" class="filters-reset">Limpiar filtros</button>
</div>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: var(--space-5);
    padding-bottom: var(--space-6);
  }

  .filter-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .filter-field label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
  }

  .filter-field select {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    min-width: 10rem;
    cursor: pointer;
  }

  .filter-field select:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .filters-reset {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-accent-hover);
    background: none;
    border: none;
    padding: var(--space-2) 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .filters-reset:hover {
    color: var(--color-accent);
  }
</style>
